# Root ignore rules for this monorepo (Flutter apps + Node backend)

# --- Misc ---
*.log
*.tmp
*.swp
.DS_Store
Thumbs.db

# --- IDEs / Editors ---
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder may contain launch/tasks you want to commit.
# Uncomment to ignore it.
#.vscode/

# --- Flutter / Dart ---
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/build/
**/coverage/
**/doc/api/

# Android toolchain local config
**/android/local.properties
**/android/.gradle/

# iOS/macOS build artifacts
**/ios/Flutter/.last_build_id
**/macos/Flutter/ephemeral/

# --- Node.js ---
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# dotenv (keep examples)
**/.env
**/.env.*
!**/.env.example

# coverage / build outputs
**/coverage/
**/.nyc_output/
**/dist/
**/build/

# caches
**/.cache/
**/.parcel-cache/
**/.turbo/
